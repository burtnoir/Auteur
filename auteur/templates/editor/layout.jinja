<!doctype html>

<head>
    <title>Auteur</title>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <link
      rel="icon"
      type="image/x-icon"
      href="{{ url_for('static', filename='assets/favicon.ico') }}"
    />
    <!-- Load Bootstrap-Flask CSS here -->
    {{ bootstrap.load_css() }}

    <!-- Font Awesome icons - free set created as a kit under my account -->
    <script src="https://kit.fontawesome.com/4bd37c9289.js" crossorigin="anonymous"></script>

    <!-- Tree plugin -->
    <link rel=stylesheet type=text/css href="{{ url_for('static', filename='lib/jstree/style.min.css') }}">
    <!-- Local Styles -->
    <link rel=stylesheet type=text/css href="{{ url_for('static', filename='css/style.css') }}">

    <!-- Now the javascript -->
    <!-- jQuery -->
    <script src="{{ url_for('static', filename='lib/jquery-3.7.1.slim.min.js') }}"></script>
    <!-- CKEditor -->
    <script src="{{ url_for('static', filename='lib/ckeditor/ckeditor.js') }}"></script>
    <!-- Tree plugin -->
    <script src="{{ url_for('static', filename='lib/jstree/jstree.min.js') }}"></script>
    <script>
        SCRIPT_ROOT = {{ request.script_root | tojson | safe }};
        document.documentElement.setAttribute('data-bs-theme', '{{ config.theme }}');
        document.documentElement.setAttribute('data-theme', '{{ config.theme }}');
    </script>
</head>

<body>
    <div class="container">
        <nav id="topnav" class="navbar navbar-expand-lg">
            {% block navbar_buttons_before %}{% endblock %}
            <a class="navbar-brand" href="{{ url_for('editor.get_project_list') }}">
                <i class="fa-regular fa-gem "></i>
                Auteur: <small>{{ _('Organise Your Writing') }}</small>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    {% block navbar_buttons_after %}{% endblock %}
                </ul>
            </div>
        </nav>
    </div>

    <div id="main-container" class="container-fluid page-flex">
      
        <div class="row">

        </div>
        {% for message in get_flashed_messages() %}
        <div class="alert alert-warning alert-dismissible" role="alert">
            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            {{ message }}
        </div>
        {% endfor %} 
      
        <div id="body-container" class="body-flex">
        {% block body %}{% endblock %}
        </div>

        <nav id="bottombar" class="navbar navbar-default navbar-fixed-bottom">
            <div class="container">
                <p class="navbar-text navbar-right"><small>&copy;Simon Brooks 2015</small></p>
                <strong><p id="statusbar" class="navbar-text"></p></strong>
            </div>
        </nav>
    </div>

    <!-- Bootstrap core JS-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>

</body>